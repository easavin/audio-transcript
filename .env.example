# --- Required ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-BotFather

# Comma-separated Telegram user IDs for ADMINS (you).
# Admins are auto-allowed and can /grant /revoke /users at runtime.
# Regular allowed users are stored in the DB — no redeploy needed to add them.
# Leave empty initially: run the bot, send /start, it will reply with your ID.
# Then add the ID here and restart — you become admin. From then on use /grant.
ADMIN_USER_IDS=

# Neon Postgres. Get it from https://console.neon.tech → connection string.
# Use the pooled connection for serverless; non-pooled is fine here.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Providers ---
STT_PROVIDER=groq
GROQ_API_KEY=gsk_...

LLM_PROVIDER=gemini
GEMINI_API_KEY=...

# --- Optional (for local fallback later) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# --- Runtime ---
# If set, the bot runs in webhook mode (required on Railway).
# Format: https://your-app.up.railway.app
# Leave empty for local polling mode.
TELEGRAM_WEBHOOK_BASE=
# Random secret — PTB uses it as the URL path and X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Railway sets PORT automatically; locally you can leave this.
PORT=8080
